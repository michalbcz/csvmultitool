#!/bin/bash
# Convenience wrapper for running csvmultitool commands

JAR_PATH="$(dirname "$0")/target/csvmultitool-1.0-SNAPSHOT.jar"

if [ ! -f "$JAR_PATH" ]; then
    echo "Error: JAR file not found at $JAR_PATH"
    echo "Please run 'mvn clean package' first"
    exit 1
fi

java -jar "$JAR_PATH" "$@"
